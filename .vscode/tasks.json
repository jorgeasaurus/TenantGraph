    {
      "label": "type-check",
      "type": "npm",
      "script": "type-check",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "react-doctor",
      "type": "npm",
      "script": "doctor",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "dev",
      "type": "npm",
      "script": "dev",
      "problemMatcher": [],
